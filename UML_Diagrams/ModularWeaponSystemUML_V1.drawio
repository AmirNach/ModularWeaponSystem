        <!-- ============================================ -->

        <mxCell id="util_hitcalc" value="&lt;p style='margin:0px;margin-top:4px;text-align:center;'&gt;&lt;b&gt;«static»&lt;/b&gt;&lt;br/&gt;&lt;b&gt;HitCalculator&lt;/b&gt;&lt;/p&gt;&lt;hr size='1'/&gt;&lt;p style='margin:0px;margin-left:4px;'&gt;+ CalcHitChance(&lt;br/&gt;    config : WeaponConfig,&lt;br/&gt;    ammo : AmmoConfig,&lt;br/&gt;    range : float,&lt;br/&gt;    posture : TargetPosture,&lt;br/&gt;    speed : float&lt;br/&gt;  ) : float&lt;br/&gt;&lt;br/&gt;+ EvalPenetration(&lt;br/&gt;    ammo : AmmoConfig,&lt;br/&gt;    obstacle : ObstacleType&lt;br/&gt;  ) : bool&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=13;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1380" y="1160" width="280" height="280" as="geometry"/>
        </mxCell>

