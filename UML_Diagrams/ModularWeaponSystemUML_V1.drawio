        <!-- WeaponConfig -> AccuracyConfig -->
        <mxCell id="arrow_wc_accuracy" style="endArrow=diamondThin;endFill=1;endSize=14;strokeWidth=2;strokeColor=#9673a6;" edge="1" parent="1" source="so_weapon" target="so_accuracy">
          <mxGeometry relative="1" as="geometry"/>
