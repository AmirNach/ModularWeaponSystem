        <mxCell id="handler_lock" value="&lt;p style='margin:0px;margin-top:4px;text-align:center;'&gt;&lt;b&gt;LockHandler&lt;/b&gt;&lt;/p&gt;&lt;hr size='1'/&gt;&lt;p style='margin:0px;margin-left:4px;font-style:italic;'&gt;implements ILockable&lt;/p&gt;&lt;hr size='1'/&gt;&lt;p style='margin:0px;margin-left:4px;'&gt;- opticsConfig : OpticsConfig&lt;br/&gt;- lockedTarget : Transform&lt;/p&gt;&lt;hr size='1'/&gt;&lt;p style='margin:0px;margin-left:4px;'&gt;+ TryLock(Transform) : bool&lt;br/&gt;+ ReleaseLock() : void&lt;br/&gt;+ IsLocked : bool&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=13;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="720" y="1430" width="260" height="220" as="geometry"/>
